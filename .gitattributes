# Normalize all text files to LF in the repository and working tree.
# eol=lf overrides core.autocrlf so Windows checkouts also get LF.
* text=auto eol=lf

# Windows batch files must use CRLF — cmd.exe does not handle LF-only .bat files
*.bat text eol=crlf

# Binary files — never rewrite line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.glb   binary
*.bin   binary
*.ptx   binary
*.lib   binary
*.dll   binary
*.exe   binary
*.pdf   binary
